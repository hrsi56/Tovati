    <string name="insight_low_initiation">מתוך המגעים שתיעדת ושבהם סימנת מי יזמה, יזמת %1$d%%. אם היית רוצה דפוס אחר, אולי שווה לדבר על זה יחד.</string>
    <string name="insight_recurring_symptom">%1$s הופיע יותר מפעם אחת לאחרונה, ובשבוע הזה של המחזור הוא הופיע ב־%2$d%% מהמחזורים המתועדים שלך.</string>
    <string name="insight_contact_without_desire">סימנת מגע מיני ביום שבו לא היה לך חשק. אם זה לא הרגיש לך נכון, אולי כדאי לשתף מישהי או מישהו שאת סומכת עליהם.</string>
    <string name="insight_high_desire_low_contact">נראה שבשבוע האחרון היה לך לא מעט חשק ומעט מגע מיני. אם זה מתאים לך, אולי בא לך ליזום קרבה?</string>
    <string name="insight_low_mood">נראה שמצב הרוח היה מעט נמוך לאחרונה. את דואגת לעצמך? אולי מגיע לך משהו קטן ונעים היום.</string>
    <string name="insight_higher_pain_relief">דיווחת לאחרונה על יותר כדורים להקלה על כאבים או תסמינים מהממוצע בשבועות מקבילים במחזורים קודמים.</string>
    <string name="insight_lower_pain_relief">איזה יופי — השבוע דיווחת על פחות כדורים להקלה מהרגיל. מקווה שזה אומר שהרגשת טוב יותר.</string>
